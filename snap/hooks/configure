#!/bin/sh -e

host="$(snapctl get host)"
secret="$(snapctl get secret)"
proxy_http="$(snapctl get proxy.http)"
proxy_https="$(snapctl get proxy.https)"
proxy_no="$(snapctl get proxy.no-proxy)"

if [ "$(which docker)" = "" ]; then
    snap install docker || true
fi

# Write proxy environment files whenever proxy settings change.
# proxy.env is sourced by the daemon wrapper to set process-level proxy vars.
# .env is the runner's env_file and injects the same vars into job containers.
: > "$SNAP_COMMON/proxy.env"
: > "$SNAP_COMMON/.env"
if [ -n "$proxy_http" ]; then
    printf 'export HTTP_PROXY="%s"\nexport http_proxy="%s"\n' "$proxy_http" "$proxy_http" >> "$SNAP_COMMON/proxy.env"
    printf 'HTTP_PROXY=%s\nhttp_proxy=%s\n' "$proxy_http" "$proxy_http" >> "$SNAP_COMMON/.env"
fi
if [ -n "$proxy_https" ]; then
    printf 'export HTTPS_PROXY="%s"\nexport https_proxy="%s"\n' "$proxy_https" "$proxy_https" >> "$SNAP_COMMON/proxy.env"
    printf 'HTTPS_PROXY=%s\nhttps_proxy=%s\n' "$proxy_https" "$proxy_https" >> "$SNAP_COMMON/.env"
fi
if [ -n "$proxy_no" ]; then
    printf 'export NO_PROXY="%s"\nexport no_proxy="%s"\n' "$proxy_no" "$proxy_no" >> "$SNAP_COMMON/proxy.env"
    printf 'NO_PROXY=%s\nno_proxy=%s\n' "$proxy_no" "$proxy_no" >> "$SNAP_COMMON/.env"
fi

if [ -z "$host" -o -z "$secret" ]; then
    echo "Both `snap set forgejo-runner host` and `snap set forgejo-runner secret` are needed to configure the runner."
    exit 0
fi

$SNAP/bin/forgejo-runner create-runner-file --instance $host --secret $secret --name "$(hostname)-runner" -c $SNAP_COMMON/forgejo-config.yaml

snapctl restart $SNAP_NAME.forgejo-runner
